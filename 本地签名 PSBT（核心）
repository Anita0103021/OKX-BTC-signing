// 用 bitcoinjs-lib + tiny-secp256k1

// 1. 解码 PSBT
const psbt = bitcoin.Psbt.fromBase64(psbtBase64);

// 2. 构造 tweaked signer
const xOnly = keyPair.publicKey.slice(1, 33);  // 去掉 02/03 前缀
const tweakHash = bitcoin.crypto.taggedHash('TapTweak', xOnly);
const tweakedSigner = keyPair.tweak(tweakHash);

// 3. 对 inputsToSign 里每个 index 签名
for (const idx of [0, 1, 3]) {
  psbt.signInput(idx, tweakedSigner, [1]); // 1 = SIGHASH_ALL
}

// 4. 导出（不要 finalize！）
const signedPsbt = psbt.toBase64();

